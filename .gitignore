# ── Environment & Secrets ─────────────────────────────────────────────────────
**/.env
**/.env.*
!**/.env.example

# ── Frontend Runtime Config ───────────────────────────────────────────────────
# config.js only contains the API URL (not secrets) — must be committed for Vercel deployment
# FrontEnd/config.js

# ── Dependencies ──────────────────────────────────────────────────────────────
**/node_modules/

# ── Package lock files (optional: remove if you want to commit them) ──────────
# **/package-lock.json
# **/yarn.lock

# ── Logs ──────────────────────────────────────────────────────────────────────
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS & Editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ── Build / Output ────────────────────────────────────────────────────────────
**/dist/
**/build/
**/.cache/
